ENABLE_THINKING=false
TEMPORARY_CHAT=false
AUTO_DELETE_CHAT=true
PUBLIC_BASE_URL=your_external_base_url_here
API_KEY=your_api_key_here

# ── Multi-account pool (recommended) ──
# JSON array of cookie objects. Overrides SECURE_1PSID/SECURE_1PSIDTS when set.
# GEMINI_COOKIES_POOL=[{"__Secure-1PSID":"xxx","__Secure-1PSIDTS":"yyy"},{"__Secure-1PSID":"aaa","__Secure-1PSIDTS":"bbb"}]

# ── Single-account (legacy, used if GEMINI_COOKIES_POOL is not set) ──
SECURE_1PSID=your_psid_value_here
SECURE_1PSIDTS=your_psidts_value_here
